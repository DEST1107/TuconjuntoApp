  "item": [
    {
      "name": "Auth - Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now().toString();",
              "pm.collectionVariables.set('registerEmail', `residente${suffix}@tuconjunto.com`);",
              "pm.collectionVariables.set('registerDocument', suffix);",
              "pm.collectionVariables.set('registerPassword', '1234');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Registro responde 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Registro exitoso', function () {",
              "    pm.expect(json.autenticado).to.eql(true);",
              "    pm.expect(json.mensaje).to.eql('Registro satisfactorio.');",
              "});",
              "pm.collectionVariables.set('residentId', json.idUsuario);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuario\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\",\n  \"nombres\": \"Nazar\",\n  \"apellidos\": \"Solarte\",\n  \"tipoDocumento\": \"CC\",\n  \"numeroDocumento\": \"{{registerDocument}}\",\n  \"telefono\": \"3001112233\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
